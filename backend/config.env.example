# Copy to config.env locally or on Hostinger (never commit config.env — it is gitignored).
# GitHub: add the same keys under Settings → Secrets and variables → Actions.
# Hostinger: prefer hPanel → Node.js → Environment variables; use config.env only if .env is blocked.
# Hostinger: use Neon *pooled* URL (host contains -pooler.neon.tech), not the direct endpoint.
# Remove channel_binding=require if connections hang on shared hosting.
DATABASE_URL=
DIRECT_URL=
# Optional: HEALTH_DB_TIMEOUT_MS=4000
# Neon on Hostinger (auto when URL contains neon.tech):
# Default: PrismaNeonHTTP (HTTPS) — avoids WebSocket non-101 errors.
# POS writes use runInTransaction (no prisma.$transaction on HTTP).
# Set PRISMA_NEON_HTTP=0 only if your host supports Neon WebSocket Pool.
# PRISMA_NEON_ADAPTER=1
# PRISMA_NEON_HTTP=0
# HEALTH_DB_TIMEOUT_MS=15000
JWT_SECRET=
# Google OAuth Web client ID (login page fetches this via GET /api/auth/google-config)
# Client secret is NOT required for this app (ID-token sign-in only).
GOOGLE_CLIENT_ID=
FRONTEND_URL=https://crownevcenter.com
NODE_ENV=production
PORT=5000
# QA: limits are relaxed by default. Set before go-live:
# RELAX_AUTH_LIMITS=false

R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Website uploads (POST /api/upload) store files only on R2:
# uploads/images/* and uploads/videos/* (max 10MB image, 80MB video)

# Gmail SMTP (OTP + password reset emails) — use App Password, not normal Gmail password
SMTP_USER=crownevecenter@gmail.com
SMTP_PASS=your-16-char-app-password
