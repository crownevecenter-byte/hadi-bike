# Optional: override API (production uses api.crownevcenter.com from apiUrl.js)
# VITE_API_URL=https://api.crownevcenter.com/api

# Google OAuth Web Client ID (Google Cloud Console → APIs & Services → Credentials)
# Optional — overrides bundled client ID and GET /api/auth/google-config
VITE_GOOGLE_CLIENT_ID=225130453736-jl6ulha3l8qc92qhboiapn4t7rkum54n.apps.googleusercontent.com

# Cloudflare R2 public URL for hero/static assets (same as backend R2_PUBLIC_URL)
VITE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev
